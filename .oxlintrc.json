{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["import", "react", "typescript", "vitest", "vue", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-console": "off",
    "no-await-in-loop": "off",
    "no-underscore-dangle": "off",
    "unicorn/prefer-add-event-listener": "off",
    "unicorn/require-post-message-target-origin": "off",
    "import/no-unassigned-import": "off"
  },
  "env": {
    "builtin": true,
    "browser": true,
    "node": true,
    "vitest": true,
    "worker": true
  },
  "ignorePatterns": ["dist/**", "node_modules/**", "playground/server/.data/**"],
  "settings": {
    "react": {
      "version": "19.2.6"
    }
  }
}
