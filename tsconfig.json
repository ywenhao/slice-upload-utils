{
  "compilerOptions": {
    "target": "ESNext",
    "module": "esnext",
    "lib": ["esnext", "dom"],
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "strict": true,
    "strictNullChecks": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "types": ["vite/client"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "test/**/*.tsx", "tsdown.config.ts"],
  "exclude": ["dist", "node_modules", "playground"]
}
