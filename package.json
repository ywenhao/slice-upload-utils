{
  "name": "slice-upload-utils",
  "version": "0.1.0",
  "description": "A library for slice upload file and download.",
  "keywords": [
    "big-file",
    "file",
    "file-chunk",
    "slice",
    "slice-upload",
    "upload",
    "分片上传",
    "大文件",
    "文件上传",
    "文件下载"
  ],
  "homepage": "https://github.com/ywenhao/slice-upload-utils#readme",
  "bugs": "https://github.com/ywenhao/slice-upload-utils/issues",
  "license": "MIT",
  "author": "Ywenhao <actions.win@foxmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ywenhao/slice-upload-utils.git"
  },
  "funding": "https://github.com/sponsors/ywenhao",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    },
    "./react": {
      "types": "./dist/react.d.mts",
      "require": "./dist/react.cjs",
      "import": "./dist/react.mjs"
    },
    "./vue": {
      "types": "./dist/vue.d.mts",
      "require": "./dist/vue.cjs",
      "import": "./dist/vue.mjs"
    }
  },
  "scripts": {
    "dev": "pnpm -C playground/vue dev",
    "build": "tsdown",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint src test --deny-warnings",
    "prepublishOnly": "pnpm build",
    "release": "bumpp && npm publish",
    "test": "vitest --environment happy-dom --maxWorkers 1 --no-file-parallelism",
    "typecheck": "pnpm typecheck:lib && pnpm typecheck:vue",
    "typecheck:lib": "tsc --noEmit",
    "typecheck:vue": "pnpm -C playground/vue typecheck"
  },
  "dependencies": {
    "spark-md5": "^3.0.2",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/spark-md5": "^3.0.2",
    "bumpp": "^11.1.0",
    "happy-dom": "^20.9.0",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.22.1",
    "typescript": "^5.1.6",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,vue}": "oxfmt",
    "*.{js,jsx,ts,tsx,vue}": "oxlint --fix"
  }
}
